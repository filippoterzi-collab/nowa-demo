# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; this .example is committed as documentation.

# Helius RPC API key (devnet tier is free, no credit card needed).
# Get one at https://dev.helius.xyz/.
NEXT_PUBLIC_HELIUS_API_KEY=

# Treasury keypair as a JSON byte array (64 numbers like [12,34,...,89]).
# SERVER-SIDE ONLY. Never expose to the client.
# Generate via: solana-keygen new --outfile ~/.config/solana/<name>.json --no-bip39-passphrase
# Extract via: cat ~/.config/solana/<name>.json | pbcopy
TREASURY_PRIVATE_KEY=

# Mock USDC SPL token mint address on Solana devnet.
# Create via: spl-token create-token --decimals 6 (with treasury keypair active)
NEXT_PUBLIC_USDC_MINT_ADDRESS=

# Treasury wallet public address. Safe to expose to the client.
NEXT_PUBLIC_TREASURY_ADDRESS=
